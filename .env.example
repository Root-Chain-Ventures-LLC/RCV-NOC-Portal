# RCV NOC Portal — environment template.
# The installer generates a real .env with strong random secrets; never commit
# a filled-in .env. See INSTALL_FOR_AGENTS.md.

# Build / runtime
PORTAL_ENVIRONMENT=production
# Image tag to pull for the Portal web + deployer images (issue #104). `latest`
# tracks the most recent build of the default branch and is always published by
# CI, so a fresh `docker compose up -d` can always resolve an image. For a
# reproducible install, pin a published release instead, e.g. PORTAL_VERSION=v0.1.0
# (see deploy/RELEASE.md for how releases are tagged and how to confirm the tag
# exists in GHCR).
PORTAL_VERSION=latest

# HTTPS enforcement — PRODUCTION DEFAULT: true (issue #117).
#
# When true (recommended for all production deployments), the OIDC issuer URL
# must start with https://. The server logs a startup warning if
# PORTAL_PUBLIC_BASE_URL is an http:// URL (misconfiguration guard). Session
# cookies are marked Secure based on the real connection scheme
# (X-Forwarded-Proto), so a Caddy TLS terminator works out of the box.
#
# DEV / LAN ESCAPE HATCH: set PORTAL_REQUIRE_HTTPS=false AND point
# PORTAL_PUBLIC_BASE_URL to an http:// URL ONLY for local/LAN dev — this is
# INSECURE for production (OIDC tokens and the SSO client secret travel in
# cleartext). The server logs a prominent "INSECURE: SSO over HTTP" warning at
# startup when require_https=false, so it is never accidentally left off.
PORTAL_REQUIRE_HTTPS=true

# Number of trusted reverse proxies in front of the app. The bundled Caddy is
# one hop (default 1); the app then reads the real client IP the outermost proxy
# observed instead of a client-forgeable X-Forwarded-For. Set to 0 if you expose
# the app directly with no proxy.
PORTAL_TRUSTED_PROXY_COUNT=1

# Force HTTPS at the bundled Caddy edge (issue #83). When "true", the Caddy :80
# block 308-redirects to https:// instead of proxying, so X-Api-Key / Bearer
# tokens never travel cleartext on a public deploy. Leave "false" (default) for
# LAN / single-VM / `tls internal` installs reached over plain http://:80 —
# turning it on there would make the site unreachable without TLS. Set "true"
# only when you have a real cert on :443 (Let's Encrypt or an external
# terminator). Read by Caddy, not the app.
PORTAL_FORCE_HTTPS_REDIRECT=false

# Platform API key TTL for module deploy keys, in days (issue #83). The key the
# Portal mints for a module at deploy time expires after this many days,
# bounding a leaked key's blast radius; a redeploy re-mints with a fresh expiry.
# 0 = never expire (legacy behaviour). Admin-created keys are unaffected.
PORTAL_MODULE_API_KEY_TTL_DAYS=365

# Secret key — REQUIRED. Generate with: openssl rand -hex 32
PORTAL_SECRET_KEY=

# Logging level (12-factor; read without the PORTAL_ prefix). Logs are JSON on
# stdout in production, human-readable in development.
LOG_LEVEL=INFO

# --- Database --------------------------------------------------------------
# The compose install uses the bundled Postgres via POSTGRES_PASSWORD below.
# For an external Postgres (14+), instead set one of:
#   PORTAL_DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/portal   (wins)
#   DATABASE_URL=postgresql://user:pass@host:5432/portal                  (generic)
# or the discrete parts: PGHOST, PGPORT, PGUSER, PGPASSWORD, PGDATABASE.
# TLS: set PGSSLMODE=verify-full (recommended) and PGSSLROOTCERT=/path/ca.crt.
# Never disable cert verification.

# Database password (used by the bundled Postgres + the web service URL).
# Generate with: openssl rand -hex 16
POSTGRES_PASSWORD=portal

# First-run admin (seeded once if no users exist; rotate at first login).
# install.sh replaces the `changeme` placeholder below with a random password and
# prints it once (issue #108) — the default credential is never persisted. If you
# set your own value here it is preserved. First login forces a rotation either way.
PORTAL_DEFAULT_ADMIN_EMAIL=admin@rcv.example.com
PORTAL_DEFAULT_ADMIN_PASSWORD=changeme

# Public base URL of the Portal — the OIDC issuer + SSO redirect base.
# MUST be set to the real https:// gateway URL in any production or
# reverse-proxy deployment; all OIDC discovery URLs and module SSO redirect
# URIs are built from this value.
#
# For a dev/LAN install (PORTAL_REQUIRE_HTTPS=false), change this to an
# http:// URL, e.g. http://192.168.1.10 or http://localhost:8080.
PORTAL_PUBLIC_BASE_URL=https://noc.example.com

# Fernet key for secrets-at-rest (Entra SSO client secret, SSO tx cookie).
# REQUIRED for SSO config to survive a restart. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PORTAL_SECRETS_ENCRYPTION_KEY=

# --- Optional: pre-seed SSO upstream config from env vars -----------------
# These variables let an automated or playground deploy configure the upstream
# IdP at first boot, without an admin clicking through Settings → Authentication.
# They are strictly optional — leave unset for the normal UI-config workflow.
# UI-saved config always takes precedence: if an admin has already configured SSO
# via the UI, these env vars are ignored on subsequent restarts.
#
# Set PORTAL_SSO_PROVIDER to one of:  entra  |  oidc
PORTAL_SSO_PROVIDER=

# Shared for both providers:
PORTAL_SSO_CLIENT_ID=
PORTAL_SSO_CLIENT_SECRET=

# Provider = entra (Microsoft Entra ID / Azure AD):
PORTAL_SSO_TENANT_ID=
PORTAL_SSO_ADMIN_GROUP_ID=       # optional — Entra group object-id → admin role
PORTAL_SSO_OPERATOR_GROUP_ID=    # optional — Entra group object-id → operator role
                                 # (module write access, e.g. site check-in/out; admin wins if in both)

# Provider = oidc (Authentik, Okta, Keycloak, generic OIDC via discovery):
PORTAL_SSO_ISSUER=               # discovery base URL, e.g. https://authentik.example.com/application/o/myapp/
PORTAL_SSO_SCOPES=               # optional, default: "openid profile email"
PORTAL_SSO_ROLE_CLAIM=           # optional, e.g. "groups"
PORTAL_SSO_ROLE_CLAIM_ADMIN_VALUE=  # optional — claim value that grants admin role
PORTAL_SSO_ROLE_CLAIM_OPERATOR_VALUE=  # optional — claim value that grants operator role

# Module deployment (issue #37). Default 'none' = registering a module deploys
# nothing. Set to 'compose' to enable one-click install on this Docker host via
# the deployer sidecar (run it with: docker compose --profile deploy up -d).
# The 'kubernetes' target is for the Helm install instead (self-contained,
# in-cluster RBAC apply — see deploy/helm: rbac.create=true), not this file.
PORTAL_ORCHESTRATOR=none
# Shared bearer token between the Portal and the deployer sidecar. Generate with:
#   openssl rand -hex 32   (leave empty to keep the deployer locked)
PORTAL_DEPLOYER_TOKEN=
# Where the Portal reaches the deployer (internal network). Default is fine.
PORTAL_DEPLOYER_URL=http://deployer:9000
# Host docker config dir mounted (read-only) into the deployer so it can pull
# private module images using this host's `docker login ghcr.io`. install.sh
# sets this automatically; override only if your docker config lives elsewhere.
# Default suits a root-run install.
PORTAL_DOCKER_CONFIG_DIR=/root/.docker
